# Flask Configuration
FLASK_SECRET_KEY=your_secret_key_here
APP_ENV=development
FLASK_DEBUG=1
FLASK_HOST=0.0.0.0
PORT=5000
TRUST_PROXY=1
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME_HOURS=12

# Google OAuth
GOOGLE_CLIENT_SECRET_FILE=path/to/client_secret.json

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================
# THE SINGLE SWITCH POINT for all LLM operations
# Options: local | groq | auto
#   - local: Use local fine-tuned LLM only
#   - groq:  Use Groq API only
#   - auto:  Try local first, fallback to Groq (DEFAULT)
LLM_PROVIDER=auto

# Local LLM Configuration (your fine-tuned model)
LOCAL_LLM_URL=http://localhost:1234/v1/chat/completions
LOCAL_LLM_MODEL=qwen2.5-coder-3b-instruct-mlx
LOCAL_LLM_TIMEOUT=30

# Groq API Configuration (secondary/fallback)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=30

# OpenAI-compatible API configuration (used by Wishlist AI advisor too)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Legacy (kept for backward compatibility with analyzer.py)
LLM_API_URL=http://localhost:1234/v1/chat/completions
